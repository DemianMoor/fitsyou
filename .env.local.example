# Fits You public site — copy to .env.local and fill from the Fits You Supabase project.
# This site is SINGLE-TENANT: it only ever talks to its own database.

# Anon key — used for public, RLS-protected reads (published content only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Used only by the subscribe write path
# (app/api/subscribe). Never exposed to the browser, never NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
