# Fits You public site — copy to .env.local and fill from the Fits You Supabase project.
# This site is SINGLE-TENANT: it only ever talks to its own database.

# Anon key — used for public, RLS-protected reads (published content only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY. Used by the subscribe/intake write paths.
# Never exposed to the browser, never NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical site origin (sitemap / OG / canonical). Production = the www host.
NEXT_PUBLIC_SITE_URL=https://www.fitsyou.net

# Transactional email (Resend). If RESEND_API_KEY or EMAIL_FROM is unset, email
# is skipped and lead capture still works. EMAIL_FROM must use a domain verified
# in Resend. LEAD_NOTIFY_TO is the operator inbox for new-lead alerts.
RESEND_API_KEY=
EMAIL_FROM=Fits You <hello@fitsyou.net>
LEAD_NOTIFY_TO=

# DO NOT set BRAND_KEY_SECRET here. It belongs ONLY to the central admin
# (control-plane) for encrypting brand service keys. The public Fits You site
# must never carry it.
